# ============================================================
# Traffic Demand Prediction - Final Available Two-Model Solution
# Models: ExtraTreesRegressor + HistGradientBoostingRegressor
# ============================================================

import os
import zipfile
import warnings
import numpy as np
import pandas as pd

from sklearn.metrics import r2_score
from sklearn.preprocessing import OrdinalEncoder
from sklearn.impute import SimpleImputer
from sklearn.compose import ColumnTransformer
from sklearn.pipeline import Pipeline
from sklearn.ensemble import ExtraTreesRegressor, HistGradientBoostingRegressor

warnings.filterwarnings("ignore")

# ============================================================
# 1. Load data
# ============================================================

ZIP_PATH = "e88186124ec611f1.zip"   # change this if the zip file name is different
EXTRACT_DIR = "traffic_dataset"
TARGET = "demand"

if os.path.exists(ZIP_PATH):
    with zipfile.ZipFile(ZIP_PATH, "r") as z:
        z.extractall(EXTRACT_DIR)

csv_files = []
for root, dirs, files in os.walk(EXTRACT_DIR):
    for file in files:
        if file.endswith(".csv"):
            csv_files.append(os.path.join(root, file))

print("CSV files found:")
for f in csv_files:
    print(f)

train_path = [p for p in csv_files if "train" in os.path.basename(p).lower()][0]
test_path = [p for p in csv_files if "test" in os.path.basename(p).lower()][0]

train = pd.read_csv(train_path)
test = pd.read_csv(test_path)

print("Train:", train.shape)
print("Test:", test.shape)

TEMP_MEDIAN = train["Temperature"].median()

# ============================================================
# 2. Feature engineering
# ============================================================

def add_features(df):
    df = df.copy()

    time_parts = df["timestamp"].astype(str).str.split(":", expand=True)
    df["hour"] = time_parts[0].astype(int)
    df["minute"] = time_parts[1].astype(int)
    df["minute_of_day"] = df["hour"] * 60 + df["minute"]

    df["time_sin"] = np.sin(2 * np.pi * df["minute_of_day"] / 1440)
    df["time_cos"] = np.cos(2 * np.pi * df["minute_of_day"] / 1440)
    df["hour_sin"] = np.sin(2 * np.pi * df["hour"] / 24)
    df["hour_cos"] = np.cos(2 * np.pi * df["hour"] / 24)

    df["Temperature_missing"] = df["Temperature"].isna().astype(int)
    df["Temperature"] = df["Temperature"].fillna(TEMP_MEDIAN)

    cat_base = ["geohash", "RoadType", "LargeVehicles", "Landmarks", "Weather"]
    for col in cat_base:
        df[col] = df[col].astype("object").fillna("Missing").astype(str)

    df["geohash_prefix3"] = df["geohash"].str[:3]
    df["geohash_prefix4"] = df["geohash"].str[:4]
    df["geohash_prefix5"] = df["geohash"].str[:5]

    df["road_lanes"] = df["RoadType"] + "_" + df["NumberofLanes"].astype(str)
    df["weather_road"] = df["Weather"] + "_" + df["RoadType"]
    df["large_landmark"] = df["LargeVehicles"] + "_" + df["Landmarks"]

    df["temp_x_lanes"] = df["Temperature"] * df["NumberofLanes"]

    return df

train_feat = add_features(train)
test_feat = add_features(test)

# ============================================================
# 3. Time-aware validation split
# ============================================================

train_mask = (
    (train_feat["day"] < 49) |
    ((train_feat["day"] == 49) & (train_feat["minute_of_day"] < 60))
)

valid_mask = (
    (train_feat["day"] == 49) &
    (train_feat["minute_of_day"] >= 60)
)

train_fold = train_feat.loc[train_mask].copy()
valid_fold = train_feat.loc[valid_mask].copy()

drop_cols = ["Index", TARGET]
feature_cols = [c for c in train_feat.columns if c not in drop_cols]

cat_cols = [
    "geohash",
    "timestamp",
    "RoadType",
    "LargeVehicles",
    "Landmarks",
    "Weather",
    "geohash_prefix3",
    "geohash_prefix4",
    "geohash_prefix5",
    "road_lanes",
    "weather_road",
    "large_landmark"
]

cat_cols = [c for c in cat_cols if c in feature_cols]
num_cols = [c for c in feature_cols if c not in cat_cols]

X_train = train_fold[feature_cols]
y_train = train_fold[TARGET]

X_valid = valid_fold[feature_cols]
y_valid = valid_fold[TARGET]

X_full = train_feat[feature_cols]
y_full = train_feat[TARGET]

X_test = test_feat[feature_cols]

print("X_train:", X_train.shape)
print("X_valid:", X_valid.shape)
print("X_test:", X_test.shape)

# ============================================================
# 4. Preprocessor
# ============================================================

preprocessor = ColumnTransformer(
    transformers=[
        (
            "cat",
            OrdinalEncoder(
                handle_unknown="use_encoded_value",
                unknown_value=-1,
                encoded_missing_value=-1
            ),
            cat_cols
        ),
        (
            "num",
            SimpleImputer(strategy="median"),
            num_cols
        )
    ],
    remainder="drop"
)

# ============================================================
# 5. Model 1: ExtraTreesRegressor
# ============================================================

et_model = Pipeline(
    steps=[
        ("preprocessor", preprocessor),
        (
            "model",
            ExtraTreesRegressor(
                n_estimators=500,
                min_samples_split=4,
                min_samples_leaf=2,
                random_state=42,
                n_jobs=-1
            )
        )
    ]
)

et_model.fit(X_train, y_train)

et_valid_pred = np.clip(et_model.predict(X_valid), 0, 1)
et_r2 = r2_score(y_valid, et_valid_pred)

print("ExtraTrees R2:", et_r2)
print("ExtraTrees Score:", max(0, 100 * et_r2))

# ============================================================
# 6. Model 2: HistGradientBoostingRegressor
# ============================================================

hgb_model = Pipeline(
    steps=[
        ("preprocessor", preprocessor),
        (
            "model",
            HistGradientBoostingRegressor(
                learning_rate=0.05,
                max_iter=600,
                max_leaf_nodes=64,
                l2_regularization=0.1,
                random_state=42
            )
        )
    ]
)

hgb_model.fit(X_train, y_train)

hgb_valid_pred = np.clip(hgb_model.predict(X_valid), 0, 1)
hgb_r2 = r2_score(y_valid, hgb_valid_pred)

print("HistGradientBoosting R2:", hgb_r2)
print("HistGradientBoosting Score:", max(0, 100 * hgb_r2))

# ============================================================
# 7. Find best 2-model validation weight
# ============================================================

best_r2 = -999
best_weight = None

for w_et in np.arange(0, 1.01, 0.01):
    w_hgb = 1 - w_et

    blend_valid = (
        w_et * et_valid_pred +
        w_hgb * hgb_valid_pred
    )

    blend_valid = np.clip(blend_valid, 0, 1)

    r2 = r2_score(y_valid, blend_valid)

    if r2 > best_r2:
        best_r2 = r2
        best_weight = (w_et, w_hgb)

print("Best ExtraTrees weight:", best_weight[0])
print("Best HistGradientBoosting weight:", best_weight[1])
print("Best 2-model R2:", best_r2)
print("Best 2-model Score:", max(0, 100 * best_r2))

# ============================================================
# 8. Train final models on full train
# ============================================================

et_final = Pipeline(
    steps=[
        ("preprocessor", preprocessor),
        (
            "model",
            ExtraTreesRegressor(
                n_estimators=600,
                min_samples_split=4,
                min_samples_leaf=2,
                random_state=42,
                n_jobs=-1
            )
        )
    ]
)

hgb_final = Pipeline(
    steps=[
        ("preprocessor", preprocessor),
        (
            "model",
            HistGradientBoostingRegressor(
                learning_rate=0.05,
                max_iter=700,
                max_leaf_nodes=64,
                l2_regularization=0.1,
                random_state=42
            )
        )
    ]
)

et_final.fit(X_full, y_full)
hgb_final.fit(X_full, y_full)

et_test_pred = np.clip(et_final.predict(X_test), 0, 1)
hgb_test_pred = np.clip(hgb_final.predict(X_test), 0, 1)

# ============================================================
# 9. Final prediction and submission
# ============================================================

w_et, w_hgb = best_weight

final_pred = (
    w_et * et_test_pred +
    w_hgb * hgb_test_pred
)

final_pred = np.clip(final_pred, 0, 1)

submission = pd.DataFrame({
    "Index": test["Index"].values,
    "demand": final_pred
})

assert list(submission.columns) == ["Index", "demand"]
assert len(submission) == len(test)
assert submission["demand"].isnull().sum() == 0

submission.to_csv("FINAL_best_available_2model.csv", index=False)

print("FINAL_best_available_2model.csv created successfully!")
print("Weights used:")
print("ExtraTrees:", w_et)
print("HistGradientBoosting:", w_hgb)
print(submission.head())
print(submission.shape)
